<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Gravity Dash</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&display=swap');
        
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            margin: 0;
            padding: 0;
            overflow: hidden;
            background-color: #050505;
            touch-action: none;
            -webkit-user-select: none;
            user-select: none;
        }

        #game-container {
            position: fixed;
            width: 100vw;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        canvas {
            display: block;
        }

        .ui-panel {
            position: absolute;
            z-index: 10;
            pointer-events: none;
            color: white;
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        .hud-top {
            position: absolute;
            top: env(safe-area-inset-top, 20px);
            left: 0;
            width: 100%;
            display: flex;
            justify-content: space-between;
            padding: 0 30px;
        }

        .menu-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 2.5rem;
            border-radius: 2rem;
            text-align: center;
            pointer-events: auto;
            box-shadow: 0 30px 60px rgba(0,0,0,0.5);
            width: 320px;
        }

        .btn-start {
            background: #fff;
            color: #000;
            padding: 1rem 2rem;
            border-radius: 1rem;
            font-weight: 800;
            font-size: 1.1rem;
            cursor: pointer;
            transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            margin-top: 2rem;
            width: 100%;
        }

        .btn-start:active {
            transform: scale(0.92);
        }

        .score-badge {
            background: rgba(255, 255, 255, 0.1);
            padding: 10px 20px;
            border-radius: 15px;
            backdrop-filter: blur(5px);
            border: 1px solid rgba(255,255,255,0.05);
        }

        .hidden { display: none !important; }

        @keyframes float {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
            100% { transform: translateY(0px); }
        }
        .float-anim { animation: float 3s ease-in-out infinite; }
    </style>
</head>
<body>

<div id="game-container">
    <canvas id="gameCanvas"></canvas>

    <div class="ui-panel">
        <!-- HUD -->
        <div id="hud" class="hud-top hidden">
            <div class="score-badge">
                <span class="text-xs uppercase opacity-50 block font-bold">Punkte</span>
                <span id="scoreDisplay" class="text-2xl font-black">0</span>
            </div>
            <div class="score-badge text-right border-emerald-500/30">
                <span class="text-xs uppercase opacity-50 block font-bold">Bestwert</span>
                <span id="highScoreDisplay" class="text-2xl font-black text-emerald-400">0</span>
            </div>
        </div>

        <!-- Start Menu -->
        <div id="startMenu" class="menu-card float-anim">
            <h1 class="text-4xl font-black mb-2 tracking-tighter italic">GRAVITY<br><span class="text-emerald-400">DASH</span></h1>
            <p class="text-white/40 text-sm mb-8">Tippe, um die Schwerkraft zu ändern.</p>
            <button class="btn-start" onclick="startGame()">LOS GEHT'S</button>
        </div>

        <!-- Game Over -->
        <div id="gameOverMenu" class="menu-card hidden">
            <h2 class="text-2xl font-black mb-1">CRASH!</h2>
            <p id="finalScore" class="text-emerald-400 font-bold mb-6 text-xl">Score: 0</p>
            <button class="btn-start" onclick="startGame()">NOCHMAL</button>
        </div>
    </div>
</div>

<script>
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');
    const scoreDisplay = document.getElementById('scoreDisplay');
    const highScoreDisplay = document.getElementById('highScoreDisplay');
    const startMenu = document.getElementById('startMenu');
    const gameOverMenu = document.getElementById('gameOverMenu');
    const hud = document.getElementById('hud');
    const finalScoreText = document.getElementById('finalScore');

    let gameActive = false;
    let score = 0;
    let highScore = localStorage.getItem('gravityDashHighscore') || 0;
    highScoreDisplay.innerText = highScore;

    let player, obstacles, particles, frameCount;
    const COLORS = {
        bg: '#050505',
        player: '#10b981', // Emerald
        obstacle: '#ffffff',
        accent: '#34d399'
    };

    class Player {
        constructor() {
            this.size = 30;
            this.x = 80;
            this.y = window.innerHeight / 2;
            this.targetY = this.y;
            this.gravity = 0.6;
            this.velocity = 0;
            this.direction = 1; // 1 = down, -1 = up
            this.glow = 0;
        }

        update() {
            this.velocity += this.gravity * this.direction;
            this.y += this.velocity;

            // Screen boundaries
            if (this.y < this.size) {
                this.y = this.size;
                this.velocity = 0;
            } else if (this.y > canvas.height - this.size) {
                this.y = canvas.height - this.size;
                this.velocity = 0;
            }

            this.glow = Math.sin(Date.now() / 200) * 10 + 20;
        }

        draw() {
            ctx.save();
            ctx.shadowBlur = this.glow;
            ctx.shadowColor = COLORS.player;
            ctx.fillStyle = COLORS.player;
            
            // Draw a rounded diamond shape
            ctx.translate(this.x, this.y);
            ctx.rotate(Math.PI / 4);
            ctx.beginPath();
            ctx.roundRect(-this.size/2, -this.size/2, this.size, this.size, 8);
            ctx.fill();
            ctx.restore();
        }
    }

    class Obstacle {
        constructor() {
            this.width = 40 + Math.random() * 40;
            this.height = 150 + Math.random() * 200;
            this.x = canvas.width + 100;
            this.onTop = Math.random() > 0.5;
            this.y = this.onTop ? 0 : canvas.height - this.height;
            this.speed = 6 + (score / 10);
            this.passed = false;
        }

        update() {
            this.x -= this.speed;
        }

        draw() {
            ctx.save();
            ctx.fillStyle = COLORS.obstacle;
            ctx.globalAlpha = 0.9;
            ctx.shadowBlur = 10;
            ctx.shadowColor = 'rgba(255,255,255,0.2)';
            
            ctx.beginPath();
            if (this.onTop) {
                ctx.roundRect(this.x, this.y - 20, this.width, this.height + 20, [0, 0, 15, 15]);
            } else {
                ctx.roundRect(this.x, this.y, this.width, this.height + 20, [15, 15, 0, 0]);
            }
            ctx.fill();
            ctx.restore();
        }
    }

    class Particle {
        constructor(x, y, color) {
            this.x = x;
            this.y = y;
            this.color = color;
            this.size = Math.random() * 4 + 1;
            this.vx = (Math.random() - 0.5) * 10;
            this.vy = (Math.random() - 0.5) * 10;
            this.alpha = 1;
        }
        update() {
            this.x += this.vx;
            this.y += this.vy;
            this.alpha -= 0.02;
        }
        draw() {
            ctx.save();
            ctx.globalAlpha = this.alpha;
            ctx.fillStyle = this.color;
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
            ctx.fill();
            ctx.restore();
        }
    }

    function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
    }

    function init() {
        resize();
        player = new Player();
        obstacles = [];
        particles = [];
        score = 0;
        frameCount = 0;
        scoreDisplay.innerText = "0";
    }

    function startGame() {
        init();
        gameActive = true;
        startMenu.classList.add('hidden');
        gameOverMenu.classList.add('hidden');
        hud.classList.remove('hidden');
        animate();
    }

    function endGame() {
        gameActive = false;
        if (score > highScore) {
            highScore = score;
            localStorage.setItem('gravityDashHighscore', highScore);
            highScoreDisplay.innerText = highScore;
        }
        finalScoreText.innerText = `Punkte: ${score}`;
        gameOverMenu.classList.remove('hidden');
    }

    function flipGravity() {
        if (!gameActive) return;
        player.direction *= -1;
        // Small burst of particles on flip
        for(let i=0; i<5; i++) particles.push(new Particle(player.x, player.y, COLORS.player));
    }

    function animate() {
        if (!gameActive) return;
        
        // Background
        ctx.fillStyle = COLORS.bg;
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        // Grid dots (minimalist background)
        ctx.fillStyle = "rgba(255,255,255,0.05)";
        for(let x=0; x<canvas.width; x+=50) {
            for(let y=0; y<canvas.height; y+=50) {
                ctx.beginPath();
                ctx.arc(x + (frameCount % 50), y, 1, 0, Math.PI*2);
                ctx.fill();
            }
        }

        // Player
        player.update();
        player.draw();

        // Obstacles
        if (frameCount % Math.max(40, 90 - Math.floor(score/2)) === 0) {
            obstacles.push(new Obstacle());
        }

        for (let i = obstacles.length - 1; i >= 0; i--) {
            const obs = obstacles[i];
            obs.update();
            obs.draw();

            // Collision
            const pBox = { 
                l: player.x - player.size/2, r: player.x + player.size/2,
                t: player.y - player.size/2, b: player.y + player.size/2 
            };
            const oBox = { l: obs.x, r: obs.x + obs.width, t: obs.y, b: obs.y + obs.height };

            if (pBox.r > oBox.l && pBox.l < oBox.r && pBox.b > oBox.t && pBox.t < oBox.b) {
                for(let j=0; j<40; j++) particles.push(new Particle(player.x, player.y, COLORS.player));
                endGame();
            }

            // Score
            if (!obs.passed && obs.x + obs.width < player.x) {
                obs.passed = true;
                score++;
                scoreDisplay.innerText = score;
            }

            if (obs.x + obs.width < -50) obstacles.splice(i, 1);
        }

        // Particles
        for (let i = particles.length - 1; i >= 0; i--) {
            particles[i].update();
            particles[i].draw();
            if (particles[i].alpha <= 0) particles.splice(i, 1);
        }

        frameCount++;
        requestAnimationFrame(animate);
    }

    // Input
    window.addEventListener('mousedown', (e) => { if(gameActive) flipGravity(); });
    window.addEventListener('touchstart', (e) => { 
        if(gameActive) {
            e.preventDefault();
            flipGravity(); 
        }
    }, { passive: false });
    window.addEventListener('keydown', (e) => {
        if (e.code === 'Space') flipGravity();
    });

    window.addEventListener('resize', resize);
    init();
</script>

</body>
</html>
